[{"data":1,"prerenderedAt":123},["Reactive",2],{"seo":3,"content-query-doYNjAgsSN":24},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":5,"title":7,"description":8,"filetitle":9,"ogTitle":7,"ogDescription":10,"ogImage":11,"twitterCard":12,"body":13,"_type":19,"_id":20,"_source":21,"_file":22,"_extension":23},"/seo","",false,"luca engelhard","luca engelhard: photgrapher, designer und also a fledgeling web developer.","seo","luca engelhard: photgrapher, designer und also a fledgeling web developer","lucaengelhard.com/images/231104-anna_geburtstag-012.jpg","summary_large_image",{"type":14,"children":15,"toc":16},"root",[],{"title":5,"searchDepth":17,"depth":17,"links":18},2,[],"markdown","content:seo.md","content","seo.md","md",{"_path":25,"_dir":26,"_draft":6,"_partial":6,"_locale":5,"title":27,"description":5,"thumbnail":28,"order":17,"body":29,"_type":19,"_id":121,"_source":21,"_file":122,"_extension":23},"/projects/indymedia","projects","indymedia","/images/indy-header.png",{"type":14,"children":30,"toc":119},[31,38,42,46,50,57,61,66,75,80,85,93,98,106,111],{"type":32,"tag":33,"props":34,"children":37},"element","word-wave",{"link":35,"text":36},"false","redesign",[],{"type":32,"tag":33,"props":39,"children":41},{"link":35,"text":40},"html",[],{"type":32,"tag":33,"props":43,"children":45},{"link":35,"text":44},"css",[],{"type":32,"tag":33,"props":47,"children":49},{"link":35,"text":48},"nodejs",[],{"type":32,"tag":51,"props":52,"children":53},"p",{},[54],{"type":55,"value":56},"text","in collaboration with:",{"type":32,"tag":33,"props":58,"children":60},{"link":35,"text":59},"Henri Kral",[],{"type":32,"tag":51,"props":62,"children":63},{},[64],{"type":55,"value":65},"Indymedia is a portal for (sometimes anonymous) publication of left-wing content. in a course for university we redesigned the corporate identity of the website and reworked the structure and look of the site. in the end we coded a working prototype of most of the pages and created a backend in nodejs with express.",{"type":32,"tag":51,"props":67,"children":68},{},[69],{"type":32,"tag":70,"props":71,"children":74},"img",{"alt":72,"src":73},"don't hate the media, become the media","/images/donthatethemedia.png",[],{"type":32,"tag":51,"props":76,"children":77},{},[78],{"type":55,"value":79},"the goal was to rework the look and feel of the website from a hard to read and trashy looking blog-site to more of a magazine-like style.\nfor that we analysed existing websites of newspapers and magazines and took ui-elements from them and incorporated those into our site.",{"type":32,"tag":51,"props":81,"children":82},{},[83],{"type":55,"value":84},"the landing page for example has a header with the newest featured articles and then current articles sorted by topic:",{"type":32,"tag":51,"props":86,"children":87},{},[88],{"type":32,"tag":70,"props":89,"children":92},{"alt":90,"src":91},"indymedia landing page","/images/indy-home.png",[],{"type":32,"tag":51,"props":94,"children":95},{},[96],{"type":55,"value":97},"another important part of the new website is the map and event overview. here you can search for events and institutions in a certain area:",{"type":32,"tag":51,"props":99,"children":100},{},[101],{"type":32,"tag":70,"props":102,"children":105},{"alt":103,"src":104},"Indymedia map","/images/indy-map%402x.png",[],{"type":32,"tag":51,"props":107,"children":108},{},[109],{"type":55,"value":110},"we created a desktop and a mobile version of the site:",{"type":32,"tag":51,"props":112,"children":113},{},[114],{"type":32,"tag":70,"props":115,"children":118},{"alt":116,"src":117},"indymedia mockup","/images/web-mockup-mobilclose-001.jpg",[],{"title":5,"searchDepth":17,"depth":17,"links":120},[],"content:projects:indymedia.md","projects/indymedia.md",1707758782322]