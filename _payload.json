portant part of any printed calendar - the calendar - but also texts about different topics relating to climate justice. the calendar not only shows legal holidays in germany, austria and switzerland, but also important political dates.",{"type":32,"tag":246,"props":247,"children":248},"gallery",{},[249],{"type":32,"tag":33,"props":250,"children":251},{},[252,258,263],{"type":32,"tag":253,"props":254,"children":257},"img",{"alt":255,"src":256},"Klimakalender","/images/klimakalender/221201-klimakalender-006.jpg",[],{"type":32,"tag":253,"props":259,"children":262},{"alt":260,"src":261},"Klimakalender Cover","/images/klimakalender/221201-klimakalender-007.jpg",[],{"type":32,"tag":253,"props":264,"children":267},{"alt":265,"src":266},"Klimakalender innen","/images/klimakalender/221201-klimakalender-010.jpg",[],{"type":32,"tag":33,"props":269,"children":270},{},[271],{"type":37,"value":272},"my main job in creating the calendar was creating the design principles of the calendar and layouting the finished product. we only used open source typefaces and one single highlight color to keep costs as low as possible.",{"type":32,"tag":33,"props":274,"children":275},{},[276,278],{"type":37,"value":277},"the calendar was published by the ",{"type":32,"tag":44,"props":279,"children":282},{"link":126,"text":280,"external":281},"unrast verlag","https://unrast-verlag.de/",[],{"title":5,"searchDepth":17,"depth":17,"links":284},[],"content:projects:klimakalender.md","projects/klimakalender.md",{"_path":288,"_dir":230,"_draft":6,"_partial":6,"_locale":5,"title":289,"description":5,"thumbnail":290,"order":17,"body":291,"_type":19,"_id":367,"_source":21,"_file":368,"_extension":23},"/projects/indymedia","indymedia","/images/indy-header.png",{"type":14,"children":292,"toc":365},[293,297,301,305,308,313,321,326,331,339,344,352,357],{"type":32,"tag":44,"props":294,"children":296},{"link":46,"text":295},"redesign",[],{"type":32,"tag":44,"props":298,"children":300},{"link":46,"text":299},"html",[],{"type":32,"tag":44,"props":302,"children":304},{"link":46,"text":303},"css",[],{"type":32,"tag":44,"props":306,"children":307},{"link":46,"text":95},[],{"type":32,"tag":33,"props":309,"children":310},{},[311],{"type":37,"value":312},"Indymedia is a portal for (sometimes anonymous) publication of left-wing content. in a course for university we redesigned the corporate identity of the website and reworked the structure and look of the site. in the end we coded a working prototype of most of the pages and created a backend in nodejs with express.",{"type":32,"tag":33,"props":314,"children":315},{},[316],{"type":32,"tag":253,"props":317,"children":320},{"alt":318,"src":319},"don't hate the media, become the media","/images/donthatethemedia.png",[],{"type":32,"tag":33,"props":322,"children":323},{},[324],{"type":37,"value":325},"the goal was to rework the look and feel of the website from a hard to read and trashy looking blog-site to more of a magazine-like style.\nfor that we analysed existing websites of newspapers and magazines and took ui-elements from them and incorporated those into our site.",{"type":32,"tag":33,"props":327,"children":328},{},[329],{"type":37,"value":330},"the landing page for example has a header with the newest featured articles and then current articles sorted by topic:",{"type":32,"tag":33,"props":332,"children":333},{},[334],{"type":32,"tag":253,"props":335,"children":338},{"alt":336,"src":337},"indymedia landing page","/images/indy-home.png",[],{"type":32,"tag":33,"props":340,"children":341},{},[342],{"type":37,"value":343},"another important part of the new website is the map and event overview. here you can search for events and institutions in a certain area:",{"type":32,"tag":33,"props":345,"children":346},{},[347],{"type":32,"tag":253,"props":348,"children":351},{"alt":349,"src":350},"Indymedia map","/images/indy-map%402x.png",[],{"type":32,"tag":33,"props":353,"children":354},{},[355],{"type":37,"value":356},"we created a desktop and a mobile version of the site:",{"type":32,"tag":33,"props":358,"children":359},{},[360],{"type":32,"tag":253,"props":361,"children":364},{"alt":362,"src":363},"indymedia mockup","/images/web-mockup-mobilclose-001.jpg",[],{"title":5,"searchDepth":17,"depth":17,"links":366},[],"content:projects:indymedia.md","projects/indymedia.md",{"_path":370,"_dir":230,"_draft":6,"_partial":6,"_locale":5,"title":371,"description":5,"thumbnail":372,"order":373,"body":374,"_type":19,"_id":737,"_source":21,"_file":738,"_extension":23},"/projects/ao3-toolkit","ao3-toolkit","images/ao3-toolkit.png",3,{"type":14,"children":375,"toc":735},[376,380,383,387,391,394,399,403,418,430,434,452,456,467,471,480,484,493,497,506,510,519,523,532,536,581,585,603,607,626,630,721,725],{"type":32,"tag":44,"props":377,"children":379},{"link":46,"text":378},"typescript",[],{"type":32,"tag":44,"props":381,"children":382},{"link":46,"text":95},[],{"type":32,"tag":44,"props":384,"children":386},{"link":46,"text":385},"axios",[],{"type":32,"tag":388,"props":389,"children":390},"hr",{},[],{"type":32,"tag":44,"props":392,"children":393},{"link":46,"text":371},[],{"type":32,"tag":33,"props":395,"children":396},{},[397],{"type":37,"value":398},"A Toolkit for interfacing with the Archive of Our Own",{"type":32,"tag":44,"props":400,"children":402},{"link":46,"text":401},"Installation",[],{"type":32,"tag":33,"props":404,"children":405},{},[406,408,416],{"type":37,"value":407},"ao3-toolkit runs on Node.js and is available as a ",{"type":32,"tag":217,"props":409,"children":413},{"href":410,"rel":411},"https://www.npmjs.com/package/ao3-toolkit",[412],"nofollow",[414],{"type":37,"value":415},"NPM package",{"type":37,"value":417},".",{"type":32,"tag":419,"props":420,"children":424},"pre",{"className":421,"code":423,"language":37,"meta":5},[422],"language-text","npm install ao3-toolkit\n",[425],{"type":32,"tag":426,"props":427,"children":428},"code",{"__ignoreMap":5},[429],{"type":37,"value":423},{"type":32,"tag":44,"props":431,"children":433},{"link":46,"text":432},"Usage",[],{"type":32,"tag":435,"props":436,"children":437},"blockquote",{},[438],{"type":32,"tag":33,"props":439,"children":440},{},[441,443,450],{"type":37,"value":442},"In a ",{"type":32,"tag":217,"props":444,"children":447},{"href":445,"rel":446},"https://archiveofourown.org/admin_posts/25888?show_comments=true",[412],[448],{"type":37,"value":449},"blog post",{"type":37,"value":451}," the admins talk about how they handle data scraping:\n\"We've put in place certain technical measures to hinder large-scale data scraping on AO3, such as rate limiting, and we're constantly monitoring our traffic for signs of abusive data collection. We do not make exceptions for researchers or those wishing to create datasets. However, we don't have a policy against responsible data collection — such as those done by academic researchers, fans backing up works to Wayback Machine or Google's search indexing. Putting systems in place that attempt to block all scraping would be difficult or impossible without also blocking legitimate uses of the site.\"",{"type":32,"tag":44,"props":453,"children":455},{"link":46,"text":454},"Logging in to ao3",[],{"type":32,"tag":419,"props":457,"children":462},{"className":458,"code":460,"language":461,"meta":5},[459],"language-ts","import { LoginSession } from \"ao3-toolkit\";\n\nconst session = await new LoginSession({\n  username: string,\n  password: string,\n}).login();\n","ts",[463],{"type":32,"tag":426,"props":464,"children":465},{"__ignoreMap":5},[466],{"type":37,"value":460},{"type":32,"tag":44,"props":468,"children":470},{"link":46,"text":469},"Fetching single works",[],{"type":32,"tag":419,"props":472,"children":475},{"className":473,"code":474,"language":461,"meta":5},[459],"import { getWorkInfo } from \"ao3-toolkit\";\n\nconst work = await getWorkInfo(id: number)\n",[476],{"type":32,"tag":426,"props":477,"children":478},{"__ignoreMap":5},[479],{"type":37,"value":474},{"type":32,"tag":