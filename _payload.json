— such as those done by academic researchers, fans backing up works to Wayback Machine or Google's search indexing. Putting systems in place that attempt to block all scraping would be difficult or impossible without also blocking legitimate uses of the site.\"",{"type":32,"tag":44,"props":414,"children":416},{"link":46,"text":415},"Logging in to ao3",[],{"type":32,"tag":380,"props":418,"children":423},{"className":419,"code":421,"language":422,"meta":5},[420],"language-ts","import { LoginSession } from \"ao3-toolkit\";\n\nconst session = await new LoginSession({\n  username: string,\n  password: string,\n}).login();\n","ts",[424],{"type":32,"tag":387,"props":425,"children":426},{"__ignoreMap":5},[427],{"type":37,"value":421},{"type":32,"tag":44,"props":429,"children":431},{"link":46,"text":430},"Fetching single works",[],{"type":32,"tag":380,"props":433,"children":436},{"className":434,"code":435,"language":422,"meta":5},[420],"import { getWorkInfo } from \"ao3-toolkit\";\n\nconst work = await getWorkInfo(id: number)\n",[437],{"type":32,"tag":387,"props":438,"children":439},{"__ignoreMap":5},[440],{"type":37,"value":435},{"type":32,"tag":44,"props":442,"children":444},{"link":46,"text":443},"Fetching work content",[],{"type":32,"tag":380,"props":446,"children":449},{"className":447,"code":448,"language":422,"meta":5},[420],"import { getWorkContent } from \"ao3-toolkit\";\n\nconst work = await getWorkContent(id: number)\n",[450],{"type":32,"tag":387,"props":451,"children":452},{"__ignoreMap":5},[453],{"type":37,"value":448},{"type":32,"tag":44,"props":455,"children":457},{"link":46,"text":456},"Fetching work stats",[],{"type":32,"tag":380,"props":459,"children":462},{"className":460,"code":461,"language":422,"meta":5},[420],"import { getWorkStats } from \"ao3-toolkit\";\n\nconst work = await getWorkStats(id: number)\n",[463],{"type":32,"tag":387,"props":464,"children":465},{"__ignoreMap":5},[466],{"type":37,"value":461},{"type":32,"tag":44,"props":468,"children":470