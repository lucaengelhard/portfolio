 find me on",{"type":32,"tag":44,"props":169,"children":172},{"link":126,"text":170,"external":171},"Instagram","https://www.instagram.com/luca__engelhard/",[],{"type":32,"tag":44,"props":174,"children":177},{"link":126,"text":175,"external":176},"Flickr","https://flickr.com/photos/benengelhard/",[],{"type":32,"tag":44,"props":179,"children":182},{"link":126,"text":180,"external":181},"github","https://github.com/lucaengelhard",[],{"title":5,"searchDepth":17,"depth":17,"links":184},[],"content:about.md","about.md",[188,247,329],{"_path":189,"_dir":190,"_draft":6,"_partial":6,"_locale":5,"title":191,"description":5,"thumbnail":192,"order":193,"body":194,"_type":19,"_id":245,"_source":21,"_file":246,"_extension":23},"/projects/klimakalender","projects","klimakalender","/images/221201-klimakalender-014.jpg",1,{"type":14,"children":195,"toc":243},[196,200,205,228,233],{"type":32,"tag":44,"props":197,"children":199},{"link":46,"text":198},"layout",[],{"type":32,"tag":33,"props":201,"children":202},{},[203],{"type":37,"value":204},"the klimakalender is a calendar made by climate activists for climate activists. in it you can find the most important part of any printed calendar - the calendar - but also texts about different topics relating to climate justice. the calendar not only shows legal holidays in germany, austria and switzerland, but also important political dates.",{"type":32,"tag":206,"props":207,"children":208},"gallery",{},[209],{"type":32,"tag":33,"props":210,"children":211},{},[212,218,223],{"type":32,"tag":213,"props":214,"children":217},"img",{"alt":215,"src":216},"Klimakalender","/images/klimakalender/221201-klimakalender-006.jpg",[],{"type":32,"tag":213,"props":219,"children":222},{"alt":220,"src":221},"Klimakalender Cover","/images/klimakalender/221201-klimakalender-007.jpg",[],{"type":32,"tag":213,"props":224,"children":227},{"alt":225,"src":226},"Klimakalender innen","/images/klimakalender/221201-klimakalender-010.jpg",[],{"type":32,"tag":33,"props":229,"children":230},{},[231],{"type":37,"value":232},"my main job in creating the calendar was creating the design principles of the calendar and layouting the finished product. we only used open source typefaces and one single highlight color to keep costs as low as possible.",{"type":32,"tag":33,"props":234,"children":235},{},[236,238],{"type":37,"value":237},"the calendar was published by the ",{"type":32,"tag":44,"props":239,"children":242},{"link":126,"text":240,"external":241},"unrast verlag","https://unrast-verlag.de/",[],{"title":5,"searchDepth":17,"depth":17,"links":244},[],"content:projects:klimakalender.md","projects/klimakalender.md",{"_path":248,"_dir":190,"_draft":6,"_partial":6,"_locale":5,"title":249,"description":5,"thumbnail":250,"order":17,"body":251,"_type":19,"_id":327,"_source":21,"_file":328,"_extension":23},"/projects/indymedia","indymedia","/images/indy-header.png",{"type":14,"children":252,"toc":325},[253,257,261,265,268,273,281,286,291,299,304,312,317],{"type":32,"tag":44,"props":254,"children":256},{"link":46,"text":255},"redesign",[],{"type":32,"tag":44,"props":258,"children":260},{"link":46,"text":259},"html",[],{"type":32,"tag":44,"props":262,"children":264},{"link":46,"text":263},"css",[],{"type":32,"tag":44,"props":266,"children":267},{"link":46,"text":95},[],{"type":32,"tag":33,"props":269,"children":270},{},[271],{"type":37,"value":272},"Indymedia is a portal for (sometimes anonymous) publication of left-wing content. in a course for university we redesigned the corporate identity of the website and reworked the structure and look of the site. in the end we coded a working prototype of most of the pages and created a backend in nodejs with express.",{"type":32,"tag":33,"props":274,"children":275},{},[276],{"type":32,"tag":213,"props":277,"children":280},{"alt":278,"src":279},"don't hate the media, become the media","/images/donthatethemedia.png",[],{"type":32,"tag":33,"props":282,"children":283},{},[284],{"type":37,"value":285},"the goal was to rework the look and feel of the website from a hard to read and trashy looking blog-site to more of a magazine-like style.\nfor that we analysed existing websites of newspapers and magazines and took ui-elements from them and incorporated those into our site.",{"type":32,"tag":33,"props":287,"children":288},{},[289],{"type":37,"value":290},"the landing page for example has a header with the newest featured articles and then current articles sorted by topic:",{"type":32,"tag":33,"props":292,"children":293},{},[294],{"type":32,"tag":213,"props":295,"children":298},{"alt":296,"src":297},"indymedia landing page","/images/indy-home.png",[],{"type":32,"tag":33,"props":300,"children":301},{},[302],{"type":37,"value":303},"another important part of the new website is the map and event overview. here you can search for events and institutions in a certain area:",{"type":32,"tag":33,"props":305,"children":306},{},[307],{"type":32,"tag":213,"props":308,"children":311},{"alt":309,"src":310},"Indymedia map","/images/indy-map%402x.png",[],{"type":32,"tag":33,"props":313,"children":314},{},[315],{"type":37,"value":316},"we created a desktop and a mobile version of the site:",{"type":32,"tag":33,"props":318,"children":319},{},[320],{"type":32,"tag":213,"props":321,"children":324},{"alt":322,"src":323},"indymedia mockup","/images/web-mockup-mobilclose-001.jpg",[],{"title":5,"searchDepth":17,"depth":17,"links":326},[],"content:projects:indymedia.md","projects/indymedia.md",{"_path":330,"_dir":190,"_draft":6,"_partial":6,"_locale":5,"title":331,"description":5,"thumbnail":332,"order":333,"body":334,"_type":19,"_id":700,"_source":21,"_file":701,"_extension":23},"/projects/ao3-toolkit","ao3-toolkit","images/ao3-toolkit.png",3,{"type":14,"children":335,"toc":698},[336,340,343,347,351,354,359,363,379,391,395,413,417,428,432,441,445,454,458,467,471,480,484,493,497,542,546,564,568,589,593,684,688],{"type":32,"tag":44,"props":337,"children":339},{"link":46,"text":338},"typescrip